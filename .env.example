# ── Variables d'environnement (à définir dans Vercel + en local pour `vercel dev`) ──
# Aucune n'utilise le préfixe VITE_ : elles restent côté serveur, jamais exposées au navigateur.

# Clé API Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIza...

# Modèle Gemini (optionnel — défaut : gemini-3.5-flash)
GEMINI_MODEL=gemini-3.5-flash

# ── Base de données Neon Postgres ──
# Ajouter Neon via Vercel → Storage (Marketplace) ; Vercel injecte DATABASE_URL automatiquement.
# En local : copier la valeur depuis le dashboard Neon (onglet "Connection string", mode "Pooled").
DATABASE_URL=postgresql://...

# ── Secret de session ──
# Générer : node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ── Auth mono-utilisateur (DÉPRÉCIÉ — remplacé par la table users) ──
# Conserver uniquement si DATABASE_URL n'est pas encore configuré.
# AUTH_USERNAME=eleve
# AUTH_PASSWORD_HASH=
