# ── Variables d'environnement (à définir dans Vercel + en local pour `vercel dev`) ──
# Aucune n'utilise le préfixe VITE_ : elles restent côté serveur, jamais exposées au navigateur.

# Clé API Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIza...

# Modèle Gemini (optionnel — défaut : gemini-3.5-flash)
GEMINI_MODEL=gemini-3.5-flash

# ── Authentification ──
# Identifiant de connexion (en clair)
AUTH_USERNAME=eleve

# Hash scrypt du mot de passe, format "saltHex:hashHex"
# Générer avec :  npm run hash-password "monMotDePasse"
AUTH_PASSWORD_HASH=

# Secret de signature des cookies de session (>= 32 octets aléatoires)
# Générer avec :  node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
